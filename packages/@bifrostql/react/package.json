{
  "name": "@bifrostql/react",
  "private": false,
  "version": "0.1.0",
  "description": "[EXPERIMENTAL, not consumed by the shipped product] React hooks and components for BifrostQL GraphQL APIs",
  "license": "MIT",
  "author": "BifrostQL",
  "repository": {
    "type": "git",
    "url": "https://github.com/standardbeagle/bifrost.git",
    "directory": "packages/@bifrostql/react"
  },
  "keywords": [
    "bifrostql",
    "graphql",
    "react",
    "hooks",
    "tanstack-query",
    "sql",
    "database",
    "table",
    "ssr"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ts": "tsc"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bifrostql/types": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/bifrost-react.cjs",
  "module": "./dist/bifrost-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/bifrost-react.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/bifrost-react.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/bifrost-react-server.js"
      },
      "require": {
        "types": "./dist/server.d.ts",
        "default": "./dist/bifrost-react-server.cjs"
      }
    }
  }
}
