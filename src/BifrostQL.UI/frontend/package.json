{
  "name": "bifrostql-ui-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "pnpm --filter @standardbeagle/edit-db build && pnpm --filter @bifrostql/binary-client build && tsc --noEmit",
