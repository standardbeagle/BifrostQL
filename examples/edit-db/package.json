    "ajv": "^8.20.0",
    "babel-loader": "^9.2.1",
    "browserslist": "^4.28.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^25.0.1",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.8"
