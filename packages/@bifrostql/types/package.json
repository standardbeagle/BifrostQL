{
  "name": "@bifrostql/types",
  "private": false,
  "version": "0.1.0",
  "description": "Shared TypeScript contract types for BifrostQL clients (SPA, React Native)",
  "license": "MIT",
  "author": "BifrostQL",
  "repository": {
    "type": "git",
    "url": "https://github.com/standardbeagle/bifrost.git",
    "directory": "packages/@bifrostql/types"
  },
  "keywords": [
    "bifrostql",
    "graphql",
    "types",
    "contract",
    "metadata",
    "sql",
    "database"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ts": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./generated": {
      "import": {
        "types": "./dist/generated/index.d.ts",
        "default": "./dist/generated/index.js"
      },
      "require": {
        "types": "./dist/generated/index.d.ts",
        "default": "./dist/generated/index.js"
      }
    }
  }
}
