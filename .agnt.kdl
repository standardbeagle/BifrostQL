// .agnt.kdl - BifrostQL UI development configuration
//
// Three services orchestrated via dev-ui.sh:
//   1. edit-db library watch build (vite --watch)
//   2. .NET backend (dotnet watch, port 5000)
//   3. Vite frontend dev server (port 5173, proxies /api + /graphql to backend)

project {
    name "bifrostui"
    type "dotnet-vite"
}

scripts {
    dev {
        run "bash dev-ui.sh"
        autostart true
        url-matchers "Frontend:\\s+{url}"
    }
    dev-lib {
        command "npx"
        args "vite" "build" "--watch" "--mode" "production"
        cwd "examples/edit-db"
    }
    dev-backend {
        run "dotnet watch run --no-hot-reload --project src/BifrostQL.UI/BifrostQL.UI.csproj -- --headless --port 5000"
        url-matchers "Now listening on {url}"
    }
    dev-frontend {
        run "pnpm dev"
        cwd "src/BifrostQL.UI/frontend"
        url-matchers "Local:\\s+{url}"
    }
}

proxies {
    dev {
        script "dev"
        fallback-port 5173
    }
}

hooks {
    on-response {
        toast true
        indicator true
    }
}

toast {
    duration 4000
    position "bottom-right"
    max-visible 3
}
