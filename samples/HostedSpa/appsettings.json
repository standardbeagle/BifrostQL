{
  "ConnectionStrings": {
    "bifrost": "Data Source=hostedspa-sample.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // Optional OIDC login (Google / Microsoft 365). Left commented out so the sample runs
  // on local auth only — Program.cs only wires OIDC when an "Oidc" section is present.
  // To enable, uncomment and supply a real issuer (and the matching AddOpenIdConnect
  // client id/secret). OIDC logins map to the same AppIdentity local auth produces, so
  // app authorization semantics are unchanged.
  // "Oidc": {
  //   "Microsoft365": { "Issuer": "https://login.microsoftonline.com/<tenant-id>/v2.0" },
  //   "Google": { "Issuer": "https://accounts.google.com" }
  // },
  "BifrostQL": {
    "Path": "/graphql",
    "Playground": "/playground",
    "DisableAuth": true,
    "Provider": "sqlite",
    "Metadata": [
      ":root { auto-join: true; de-pluralize: false; default-limit: 100; }"
    ]
  }
}
