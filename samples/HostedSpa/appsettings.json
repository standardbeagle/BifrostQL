{
  "ConnectionStrings": {
    "bifrost": "Data Source=hostedspa-sample.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BifrostQL": {
    "Path": "/graphql",
    "Playground": "/playground",
    "DisableAuth": true,
    "Provider": "sqlite",
    "Metadata": [
      ":root { auto-join: true; de-pluralize: false; default-limit: 100; }"
    ]
  }
}
