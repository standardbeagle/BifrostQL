{
  "entities": {
    "main.members": {
      "label": "Members",
      "icon": "person",
      "navPlacement": "main",
      "displayFields": [ "first_name", "last_name" ],
      "fields": {
        "first_name": { "widget": "text", "group": "Identity" },
        "last_name": { "widget": "text", "group": "Identity" },
        "email": { "widget": "text", "validation": "email", "group": "Contact", "helpText": "Primary contact email." },
        "phone": { "widget": "text", "group": "Contact" },
        "status": { "widget": "select", "group": "Membership" },
        "joined_on": { "widget": "datepicker", "group": "Membership" },
        "household_id": { "widget": "fk-lookup", "group": "Membership" },
        "user_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "helpText": "Linked login account. Admin-only."
        },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        },
        "deleted_at": {
          "widget": "datepicker",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Soft-delete timestamp. Admin-only audit field."
        }
      },
      "grid": {
        "defaultColumns": [ "first_name", "last_name", "email", "phone", "status" ],
        "defaultSort": [ "last_name asc" ],
        "defaultFilters": [ "status = active" ],
        "savedViews": {
          "active": {
            "name": "Active Members",
            "filters": [ "status = active" ]
          }
        },
        "bulkActions": [ "export", "email" ]
      },
      "relationships": {
        "household": {
          "label": "Household",
          "targetEntity": "main.households",
          "kind": "foreignKeySelector",
          "foreignKeyField": "household_id"
        },
        "householdMembers": {
          "label": "Household Links",
          "targetEntity": "main.household_members",
          "kind": "childCollection",
          "foreignKeyField": "member_id",
          "displayColumns": [ "household_id", "relationship" ]
        }
      }
    },
    "main.households": {
      "label": "Households",
      "icon": "home",
      "navPlacement": "main",
      "displayFields": [ "name" ],
      "fields": {
        "name": { "widget": "text", "group": "Identity" },
        "address_line1": { "widget": "text", "group": "Address" },
        "city": { "widget": "text", "group": "Address" },
        "region": { "widget": "text", "group": "Address" },
        "postal_code": { "widget": "text", "group": "Address" },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "name", "city", "region", "postal_code" ],
        "defaultSort": [ "name asc" ]
      },
      "relationships": {
        "members": {
          "label": "Members",
          "targetEntity": "main.members",
          "kind": "childCollection",
          "foreignKeyField": "household_id",
          "displayColumns": [ "first_name", "last_name", "status" ]
        },
        "householdMembers": {
          "label": "Household Members",
          "targetEntity": "main.household_members",
          "kind": "childCollection",
          "foreignKeyField": "household_id",
          "displayColumns": [ "member_id", "relationship" ]
        }
      }
    },
    "main.household_members": {
      "label": "Household Members",
      "icon": "group",
      "navPlacement": "main",
      "displayFields": [ "relationship" ],
      "fields": {
        "household_id": {
          "widget": "fk-lookup",
          "group": "Link",
          "helpText": "Household this membership link belongs to."
        },
        "member_id": {
          "widget": "fk-lookup",
          "group": "Link",
          "helpText": "Member linked into the household."
        },
        "relationship": {
          "widget": "select",
          "group": "Link",
          "helpText": "Role within the household (head, spouse, child)."
        },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "household_id", "member_id", "relationship" ],
        "defaultSort": [ "household_id asc" ]
      },
      "relationships": {
        "household": {
          "label": "Household",
          "targetEntity": "main.households",
          "kind": "foreignKeySelector",
          "foreignKeyField": "household_id"
        },
        "member": {
          "label": "Member",
          "targetEntity": "main.members",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_id"
        }
      }
    },
    "main.membership_plans": {
      "label": "Membership Plans",
      "icon": "card_membership",
      "navPlacement": "main",
      "displayFields": [ "name" ],
      "fields": {
        "name": { "widget": "text", "group": "Identity" },
        "description": { "widget": "textarea", "group": "Identity", "helpText": "What the plan includes." },
        "billing_period": { "widget": "select", "group": "Billing", "helpText": "How often dues are billed (annual, monthly)." },
        "price_cents": { "widget": "number", "group": "Billing", "helpText": "Plan price in cents." },
        "is_active": { "widget": "checkbox", "group": "Billing", "helpText": "Whether the plan can be selected for new memberships." },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "name", "billing_period", "price_cents", "is_active" ],
        "defaultSort": [ "name asc" ],
        "defaultFilters": [ "is_active = 1" ],
        "savedViews": {
          "active": {
            "name": "Active Plans",
            "filters": [ "is_active = 1" ]
          }
        }
      },
      "relationships": {
        "memberMemberships": {
          "label": "Memberships",
          "targetEntity": "main.member_memberships",
          "kind": "childCollection",
          "foreignKeyField": "plan_id",
          "displayColumns": [ "member_id", "start_date", "status" ]
        }
      }
    },
    "main.member_memberships": {
      "label": "Member Memberships",
      "icon": "badge",
      "navPlacement": "main",
      "displayFields": [ "status" ],
      "fields": {
        "member_id": {
          "widget": "fk-lookup",
          "group": "Enrollment",
          "helpText": "Member enrolled in the plan."
        },
        "plan_id": {
          "widget": "fk-lookup",
          "group": "Enrollment",
          "helpText": "Membership plan for this term."
        },
        "start_date": { "widget": "datepicker", "group": "Term" },
        "end_date": { "widget": "datepicker", "group": "Term", "helpText": "Renewal / expiry date. Empty for open-ended." },
        "status": { "widget": "select", "group": "Term" },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "member_id", "plan_id", "start_date", "end_date", "status" ],
        "defaultSort": [ "start_date desc" ],
        "defaultFilters": [ "status = active" ],
        "savedViews": {
          "active": {
            "name": "Active Memberships",
            "filters": [ "status = active" ]
          }
        }
      },
      "relationships": {
        "member": {
          "label": "Member",
          "targetEntity": "main.members",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_id"
        },
        "plan": {
          "label": "Plan",
          "targetEntity": "main.membership_plans",
          "kind": "foreignKeySelector",
          "foreignKeyField": "plan_id"
        },
        "duesInvoices": {
          "label": "Dues Invoices",
          "targetEntity": "main.dues_invoices",
          "kind": "childCollection",
          "foreignKeyField": "member_membership_id",
          "displayColumns": [ "amount_cents", "due_on", "status" ]
        }
      }
    },
    "main.dues_invoices": {
      "label": "Dues Invoices",
      "icon": "receipt_long",
      "navPlacement": "main",
      "displayFields": [ "amount_cents" ],
      "fields": {
        "member_id": {
          "widget": "fk-lookup",
          "group": "Billing",
          "helpText": "Member the invoice is billed to."
        },
        "member_membership_id": {
          "widget": "fk-lookup",
          "group": "Billing",
          "helpText": "Membership term this invoice covers. Optional."
        },
        "amount_cents": { "widget": "number", "group": "Billing", "helpText": "Invoiced amount in cents." },
        "issued_on": { "widget": "datepicker", "group": "Schedule" },
        "due_on": { "widget": "datepicker", "group": "Schedule" },
        "status": { "widget": "select", "group": "Schedule" },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "member_id", "amount_cents", "issued_on", "due_on", "status" ],
        "defaultSort": [ "due_on desc" ],
        "defaultFilters": [ "status = open" ],
        "savedViews": {
          "open": {
            "name": "Open Invoices",
            "filters": [ "status = open" ]
          }
        },
        "bulkActions": [ "export" ]
      },
      "relationships": {
        "member": {
          "label": "Member",
          "targetEntity": "main.members",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_id"
        },
        "membership": {
          "label": "Membership",
          "targetEntity": "main.member_memberships",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_membership_id"
        },
        "payments": {
          "label": "Payments",
          "targetEntity": "main.dues_payments",
          "kind": "childCollection",
          "foreignKeyField": "invoice_id",
          "displayColumns": [ "amount_cents", "paid_on", "method" ]
        }
      }
    },
    "main.dues_payments": {
      "label": "Dues Payments",
      "icon": "payments",
      "navPlacement": "main",
      "displayFields": [ "amount_cents" ],
      "fields": {
        "invoice_id": {
          "widget": "fk-lookup",
          "group": "Payment",
          "helpText": "Invoice this payment is applied against."
        },
        "amount_cents": { "widget": "number", "group": "Payment", "helpText": "Payment amount in cents." },
        "paid_on": { "widget": "datepicker", "group": "Payment" },
        "method": { "widget": "select", "group": "Payment", "helpText": "Payment method (card, cash, check)." },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "invoice_id", "amount_cents", "paid_on", "method" ],
        "defaultSort": [ "paid_on desc" ]
      },
      "relationships": {
        "invoice": {
          "label": "Invoice",
          "targetEntity": "main.dues_invoices",
          "kind": "foreignKeySelector",
          "foreignKeyField": "invoice_id"
        }
      }
    },
    "main.events": {
      "label": "Events",
      "icon": "event",
      "navPlacement": "main",
      "displayFields": [ "title" ],
      "fields": {
        "title": { "widget": "text", "group": "Identity" },
        "description": { "widget": "textarea", "group": "Identity", "helpText": "What the event is about." },
        "location": { "widget": "text", "group": "Schedule", "helpText": "Where the event is held." },
        "starts_at": { "widget": "datepicker", "group": "Schedule", "helpText": "When the event starts." },
        "ends_at": { "widget": "datepicker", "group": "Schedule", "helpText": "When the event ends. Empty for open-ended." },
        "capacity": { "widget": "number", "group": "Schedule", "helpText": "Maximum attendees. Empty for unlimited." },
        "created_at": {
          "widget": "datepicker",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Record creation timestamp. Admin-only, system-managed."
        },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "title", "location", "starts_at", "ends_at", "capacity" ],
        "defaultSort": [ "starts_at desc" ],
        "savedViews": {
          "upcoming": {
            "name": "Upcoming Events",
            "filters": [ "starts_at >= now" ]
          }
        }
      },
      "relationships": {
        "rsvps": {
          "label": "RSVPs",
          "targetEntity": "main.event_rsvps",
          "kind": "childCollection",
          "foreignKeyField": "event_id",
          "displayColumns": [ "member_id", "response", "guests" ]
        },
        "attendance": {
          "label": "Attendance",
          "targetEntity": "main.event_attendance",
          "kind": "childCollection",
          "foreignKeyField": "event_id",
          "displayColumns": [ "member_id", "checked_in_at" ]
        }
      }
    },
    "main.event_rsvps": {
      "label": "Event RSVPs",
      "icon": "how_to_reg",
      "navPlacement": "related",
      "displayFields": [ "response" ],
      "fields": {
        "event_id": {
          "widget": "fk-lookup",
          "group": "RSVP",
          "helpText": "Event being responded to."
        },
        "member_id": {
          "widget": "fk-lookup",
          "group": "RSVP",
          "helpText": "Member responding to the event."
        },
        "response": {
          "widget": "select",
          "group": "RSVP",
          "helpText": "Tap to set your response: yes, no, or maybe."
        },
        "guests": {
          "widget": "number",
          "group": "RSVP",
          "helpText": "How many extra guests you are bringing."
        },
        "responded_at": {
          "widget": "datepicker",
          "group": "RSVP",
          "readOnly": true,
          "helpText": "When the response was recorded."
        },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "event_id", "member_id", "response", "guests", "responded_at" ],
        "defaultSort": [ "responded_at desc" ]
      },
      "relationships": {
        "event": {
          "label": "Event",
          "targetEntity": "main.events",
          "kind": "foreignKeySelector",
          "foreignKeyField": "event_id"
        },
        "member": {
          "label": "Member",
          "targetEntity": "main.members",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_id"
        }
      }
    },
    "main.event_attendance": {
      "label": "Event Attendance",
      "icon": "check_circle",
      "navPlacement": "related",
      "displayFields": [ "checked_in_at" ],
      "fields": {
        "event_id": {
          "widget": "fk-lookup",
          "group": "Attendance",
          "helpText": "Event the member checked in to."
        },
        "member_id": {
          "widget": "fk-lookup",
          "group": "Attendance",
          "helpText": "Member who checked in."
        },
        "checked_in_at": {
          "widget": "datepicker",
          "group": "Attendance",
          "readOnly": true,
          "helpText": "Tap check-in to record arrival at the event."
        },
        "tenant_id": {
          "widget": "fk-lookup",
          "group": "Admin",
          "visible": false,
          "readOnly": true,
          "helpText": "Owning club. Admin-only, system-managed."
        }
      },
      "grid": {
        "defaultColumns": [ "event_id", "member_id", "checked_in_at" ],
        "defaultSort": [ "checked_in_at desc" ]
      },
      "relationships": {
        "event": {
          "label": "Event",
          "targetEntity": "main.events",
          "kind": "foreignKeySelector",
          "foreignKeyField": "event_id"
        },
        "member": {
          "label": "Member",
          "targetEntity": "main.members",
          "kind": "foreignKeySelector",
          "foreignKeyField": "member_id"
        }
      }
    }
  }
}
