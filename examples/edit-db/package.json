  "style": "./dist/edit-db.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/editor.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/editor.umd.cjs"
      }
    },
    "./style.css": "./dist/edit-db.css"
  }
