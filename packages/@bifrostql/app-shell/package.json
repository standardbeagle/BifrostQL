{
  "name": "@bifrostql/app-shell",
  "private": false,
  "version": "0.1.0",
  "description": "[EXPERIMENTAL, not consumed by the shipped product] Reusable React app shell and CRUD primitives for BifrostQL",
  "license": "MIT",
  "author": "BifrostQL",
  "repository": {
    "type": "git",
    "url": "https://github.com/standardbeagle/bifrost.git",
    "directory": "packages/@bifrostql/app-shell"
  },
  "keywords": [
    "bifrostql",
    "graphql",
    "react",
    "app-shell",
    "crud",
    "metadata",
    "sql",
    "database"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "ts": "tsc"
  },
  "peerDependencies": {
    "@bifrostql/react": "^0.1.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bifrostql/types": "workspace:*"
  },
  "devDependencies": {
    "@bifrostql/react": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/bifrost-app-shell.cjs",
  "module": "./dist/bifrost-app-shell.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/bifrost-app-shell.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/bifrost-app-shell.cjs"
      }
    }
  }
}
