{
  "name": "bifrostql",
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.1",
  "description": "Is a magical bridge connecting your front end code to your SQL datasources.",
  "main": "index.js",
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "build": "pnpm -r --if-present --sort build",
    "test": "dotnet test BifrostQL.sln --no-restore && pnpm test:js",
    "test:js": "pnpm --filter @bifrostql/codegen --filter @bifrostql/binary-client --filter @bifrostql/types --filter @bifrostql/react --filter @bifrostql/app-shell --filter @standardbeagle/edit-db --filter bifrostql-ui-frontend --if-present test",
    "dev": "bash dev-ui.sh",
    "dev:ui": "bash dev-ui.sh",
    "dev:lib": "pnpm --dir examples/edit-db exec vite build --watch",
    "dev:backend": "dotnet watch run --no-hot-reload --project src/BifrostQL.UI/BifrostQL.UI.csproj -- --headless --port 5000",
    "dev:frontend": "cd src/BifrostQL.UI/frontend && pnpm dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@standardbeagle/virtual-router": "^1.2.0",
    "ajv": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "ajv": "$ajv",
      "form-data": "^4.0.6",
      "js-yaml": "^4.2.0"
    }
  }
}
