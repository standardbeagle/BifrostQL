{
  "name": "bifrostql-ui-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "pnpm --filter @standardbeagle/edit-db build && pnpm --filter @bifrostql/binary-client build && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/client": "^4.2.5",
    "@bifrostql/binary-client": "workspace:*",
    "@standardbeagle/edit-db": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "graphql": "^17.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.8"
  }
}
