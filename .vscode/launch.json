{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "BifrostQL.Host (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-host",
            "program": "${workspaceFolder}/src/BifrostQL.Host/bin/Debug/net10.0/BifrostQL.Host.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/BifrostQL.Host",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5000"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "BifrostQL.Tool (CLI)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tool",
            "program": "${workspaceFolder}/src/BifrostQL.Tool/bin/Debug/net10.0/BifrostQL.Tool.dll",
            "args": ["help"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": "BifrostQL.UI (Desktop)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-ui",
            "program": "${workspaceFolder}/src/BifrostQL.UI/bin/Debug/net10.0/BifrostQL.UI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/BifrostQL.UI",
            "stopAtEntry": false
        },
        {
            "name": "Run Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tests",
            "program": "dotnet",
            "args": ["test", "--no-build"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
